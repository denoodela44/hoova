# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/sika_db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_REFRESH_SECRET="your-refresh-secret-change-this"

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Server
PORT=3001
NODE_ENV=development
CLIENT_URL="http://localhost:5173"

# SendGrid (email alerts)
SENDGRID_API_KEY="SG.your-key"
FROM_EMAIL="noreply@sika.com.gh"

# Hubtel (Ghana SMS OTP)
HUBTEL_CLIENT_ID="your-client-id"
HUBTEL_CLIENT_SECRET="your-secret"
HUBTEL_SENDER_ID="SIKA"

# Paystack (payments)
PAYSTACK_SECRET_KEY="sk_test_your-key"
PAYSTACK_PUBLIC_KEY="pk_test_your-key"

# Web Push (push notifications)
VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_EMAIL="mailto:admin@sika.com.gh"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"
